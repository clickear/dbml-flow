{
  "name": "dbml-flow",
  "type": "module",
  "homepage": "https://gwendalbroudin.github.io/dbml-flow",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "test:saved-views": "esbuild src/lib/views/saved-views.test.ts --bundle --platform=node --format=esm --outfile=/tmp/dbml-flow-saved-views.test.mjs && node --test /tmp/dbml-flow-saved-views.test.mjs",
    "test:source-map": "esbuild src/lib/dbml/source-map.test.ts --bundle --platform=node --format=esm --outfile=/tmp/dbml-flow-source-map.test.mjs && node --test /tmp/dbml-flow-source-map.test.mjs",
    "test:structure-tree": "esbuild src/lib/views/structure-tree.test.ts --bundle --platform=node --format=esm --outfile=/tmp/dbml-flow-structure-tree.test.mjs && node --test /tmp/dbml-flow-structure-tree.test.mjs",
    "test:viewer": "esbuild src/components/viewer/viewer.helper.test.ts --bundle --platform=node --format=esm --outfile=/tmp/dbml-flow-viewer-helper.test.mjs && node --test /tmp/dbml-flow-viewer-helper.test.mjs",
    "test:flow": "esbuild src/lib/flow/focus.helpers.test.ts --bundle --platform=node --format=esm --outfile=/tmp/dbml-flow-focus-helper.test.mjs && node --test /tmp/dbml-flow-focus-helper.test.mjs",
    "preview": "vite preview",
    "predeploy": "tsc && vite build ",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dbml/core": "^7.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "fflate": "^0.8.2",
    "html-to-image": "^1.11.13",
    "lodash-es": "^4.18.1",
    "lodash.uniqby": "^4.7.0",
    "lucide-react": "^1.9.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/lodash.uniqby": "^4.7.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild-wasm": "^0.28.0",
    "gh-pages": "^6.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "main": "/index.html"
}
